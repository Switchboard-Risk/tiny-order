#!/usr/bin/env ruby
# frozen_string_literal: true

$LOAD_PATH.unshift(File.expand_path("../lib", __dir__))

require "db"
require "order_service"
require "illegal_transition"
require "insufficient_stock"
require_relative "../db/seeds"

def usage
  puts <<~USAGE
    Usage:
      bin/orders seed              Load the sample catalog into the store
      bin/orders catalog           List products with price and stock
      bin/orders create            Create a new draft order, print its id
      bin/orders add ID SKU QTY    Add QTY of SKU to draft order ID
      bin/orders submit ID         Submit order ID (reserves stock)
      bin/orders pay ID            Mark order ID paid
      bin/orders fulfill ID        Fulfill order ID (decrements stock)
      bin/orders cancel ID         Cancel order ID (releases any reserved stock)
      bin/orders show ID           Show one order in detail
      bin/orders list              List all orders
      bin/orders demo              Self-contained end-to-end run (in-memory)
      bin/orders help              Show this message
  USAGE
end

def fmt_money(cents)
  format("$%.2f", cents / 100.0)
end

def fmt_time(time)
  time.strftime("%H:%M:%S")
end

STATE_VERB = {
  submitted: "submit!", paid: "pay!", fulfilled: "fulfill!", canceled: "cancel!"
}.freeze

def print_catalog(products)
  puts "Catalog:"
  if products.empty?
    puts "  (empty — run `bin/orders seed`)"
    return
  end
  products.each do |p|
    reserved = p.reserved_quantity.positive? ? " (#{p.reserved_quantity} reserved)" : ""
    puts "  #{p.sku.ljust(12)} #{p.name.ljust(20)} #{fmt_money(p.price_cents).rjust(8)}" \
         "   stock: #{p.stock_quantity}, available: #{p.available}#{reserved}"
  end
end

def print_order(order)
  puts "Order ##{order.id} (state: #{order.state})"
  if order.line_items.empty?
    puts "  (no line items)"
  else
    puts "  Line items:"
    order.line_items.each do |li|
      puts "    #{li.quantity}x #{li.sku} @ #{fmt_money(li.unit_price_cents)}"
    end
    puts "  Total: #{fmt_money(order.total)}"
  end
  puts "  paid_at: #{order.paid_at.strftime('%Y-%m-%d %H:%M:%S %z')}" if order.paid_at
end

def print_audit(order)
  puts "  Audit log:"
  if order.audit_log.empty?
    puts "    (empty)"
    return
  end
  width = order.audit_log.map { |e| e[:from].to_s.length }.max
  order.audit_log.each do |e|
    puts "    #{fmt_time(e[:at])}  #{e[:from].to_s.ljust(width)} → #{e[:to]}"
  end
end

def with_service
  db = DB.connect
  yield OrderService.new(db)
rescue IllegalTransition, InsufficientStock, ArgumentError => e
  warn "Error: #{e.message}"
  exit 1
end

def run_demo
  puts "(demo runs against a throwaway in-memory database)\n\n"
  db = DB.connect(":memory:")
  service = OrderService.new(db)
  Seeds.load(service.products)

  print_catalog(service.products.all)
  puts

  order = service.create
  service.add_item(order.id, "WIDGET-1", 2)
  service.add_item(order.id, "GADGET-7", 1)
  puts "Created order ##{order.id} and added items:"
  print_order(service.find(order.id))
  puts

  %i[submit pay fulfill].each do |step|
    service.public_send("#{step}!", order.id)
    puts "→ #{step}!  (state: #{service.find(order.id).state})"
  end
  puts

  print_catalog(service.products.all)
  puts
  print_audit(service.find(order.id))
end

command = ARGV[0]
args = ARGV[1..] || []

case command
when "seed"
  with_service do |service|
    Seeds.load(service.products)
    puts "Seeded #{Seeds::PRODUCTS.length} products."
  end
when "catalog"
  with_service { |service| print_catalog(service.products.all) }
when "create"
  with_service do |service|
    order = service.create
    puts "Created order ##{order.id} (state: draft)"
  end
when "add"
  id, sku, qty = args
  abort "Usage: bin/orders add ID SKU QTY" unless id && sku && qty
  with_service do |service|
    order = service.add_item(id.to_i, sku, qty.to_i)
    puts "Added #{qty}x #{sku} to order ##{order.id}."
    print_order(order)
  end
when "submit", "pay", "fulfill", "cancel"
  id = args[0]
  abort "Usage: bin/orders #{command} ID" unless id
  with_service do |service|
    order = service.public_send("#{command}!", id.to_i)
    puts "Order ##{order.id} → #{order.state}"
  end
when "show"
  id = args[0]
  abort "Usage: bin/orders show ID" unless id
  with_service do |service|
    order = service.find(id.to_i) or abort "No such order: ##{id}"
    print_order(order)
    print_audit(order)
  end
when "list"
  with_service do |service|
    orders = service.all
    if orders.empty?
      puts "(no orders yet)"
    else
      orders.each do |o|
        puts "##{o.id}  #{o.state.to_s.ljust(10)} #{o.line_items.length} item(s)  #{fmt_money(o.total)}"
      end
    end
  end
when "demo"
  run_demo
when "help", nil
  usage
else
  warn "Unknown command: #{command}"
  usage
  exit 1
end
